# Toodle Environment Configuration
# Copy this file to .env.local and update with your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: sqlite | postgres
DATABASE_TYPE=sqlite

# Primary database connection string (used based on DATABASE_TYPE)
# For PostgreSQL: Use this as your active database connection
# For SQLite: This is used if SQLLITE_DATABASE_URL is not set
DATABASE_URL=./data/toodle.db

# SQLite database path (when DATABASE_TYPE=sqlite)
SQLLITE_DATABASE_URL=./data/toodle.db

# Production database URL (optional - for reference/deployment)
# Supabase PostgreSQL:
# Get from: Supabase Dashboard > Settings > Database > Connection string
# Use "Transaction mode" (port 6543) for better connection pooling
# PROD_DATABASE_URL=postgresql://USER:PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# =============================================================================
# SUPABASE CLIENT CONFIGURATION (Optional - for frontend features)
# =============================================================================

# Get from: Supabase Dashboard > Settings > API
# NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Node environment: development | production | test
NODE_ENV=development

# =============================================================================
# NOTES
# =============================================================================

# To switch from SQLite to Local PostgreSQL:
# 1. Set DATABASE_TYPE=postgres
# 2. Set DATABASE_URL to your local PostgreSQL connection string
# 3. Run migration scripts:
#    npm run pg:test    - Test connection
#    npm run pg:create  - Create database (if needed)
#    npm run pg:migrate - Apply schema
#    npm run pg:import  - Import data from SQLite
# 4. Restart your development server

# To use Supabase (Cloud PostgreSQL):
# 1. Get your connection string from Supabase Dashboard
# 2. Set DATABASE_TYPE=postgres
# 3. Set DATABASE_URL to your Supabase connection string
# 4. Run: npm run supabase:setup
# 5. Optionally run: npm run supabase:import (to import SQLite data)
# 6. Restart your development server
# See SUPABASE_SETUP.md for detailed instructions

# Production Deployment:
# - Set DATABASE_TYPE=postgres
# - Set DATABASE_URL to your production PostgreSQL connection string
# - Use Supabase or managed PostgreSQL (AWS RDS, DigitalOcean, etc.)
# - Configure environment variables in your hosting platform (Vercel, etc.)
# - Never commit .env.local to version control
